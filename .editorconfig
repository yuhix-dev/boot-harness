root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

# Google Java Style: 2-space indent, 100-char line length
[*.java]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{gradle,groovy}]
indent_style = tab
indent_size = 4

[*.{xml,html}]
indent_style = space
indent_size = 4

[*.sql]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
